# Configuración de conexión a Metabase.
# Copia este archivo a .env y coloca los valores reales.
# El archivo .env NO debe subirse al repositorio.

METABASE_URL="https://analisisdatos.seniat.gob.ve"
METABASE_API_KEY="coloca-aqui-tu-api-key"
METABASE_DATABASE_ID=22
METABASE_DW_ID=21

# Segundos que dura la caché de datos en memoria
CACHE_DURATION=30
